<h1>Journal Entries: <%= @place.name %></h1>

<% @entries.each do |entry| %>
  <h3><%= entry.title %></h3>
  <p><%= entry.occurred_on.strftime("%B %d, %Y") %></p>
  <p><%= entry.description %></p>
  <hr>
<% end %>

<%= link_to "New Post", new_place_entry_path(@place) %>
&nbsp;&nbsp;
<%= link_to "Back to Places", places_path %>
